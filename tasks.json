{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Copy file and line",
      "type": "process",
      "command": "bash",
      "args": ["-lc", "printf '%s' \"$AI_FILE_LINE\" | clip.exe"],
      "options": {
        "env": {
          "AI_FILE_LINE": "${file} L${lineNumber}"
        }
      },
      "presentation": {
        "reveal": "never",
        "echo": false,
        "focus": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Run Current Test File",
      "type": "shell",
      "command": "npx vitest related ${file} --coverage",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Copy article content for WordPress",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bun run ~/dev/article-copy-paste-vscode-task/src/main.ts < '${file}' | iconv -f utf-8 -t utf-16le | /mnt/c/Windows/System32/clip.exe; seq 56 | while read i; do echo; done > '${file}'"
      ],
      "presentation": {
        "reveal": "never",
        "echo": false,
        "focus": false,
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
